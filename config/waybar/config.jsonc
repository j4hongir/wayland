{
    "layer": "top",
    "spacing": 4,
    "height": 0,

    "margin-top": 3,
    "margin-right": 3,
    "margin-bottom": 0,
    "margin-left": 3,

    "modules-left": [
        "sway/workspaces",
        "hyprland/workspaces"   
    ],

    "modules-center": [
        "idle_inhibitor",
        "clock",
        "custom/notification"
    ],

    "modules-right": [
        "hyprland/submap",
        "sway/mode",
        "tray",
        "hyprland/language",
        "sway/language",
        "backlight",
        "pulseaudio",
        "power-profiles-daemon",
        "battery"
    ],
    
    "sway/workspaces": {
        "format": "{icon}",
        "tooltip": false,
        "format-icons": {
            "1": "ůį≤†",
            "2": "ůį≤Ę",
            "3": "ůį≤§",
            "4": "ůį≤¶",
            "5": "ůį≤®",
            "urgent": "ÔĀ™",
            "active": "ÔÜí",
            "default": "ÔĄĎ"
    }
    },
    
    "hyprland/workspaces": {
        "format": "{icon}",
        "tooltip": false,
        "format-icons": {
            "1": "ÔĄĎ",
            "2": "ÔĄĎ",
            "3": "ÔĄĎ",
            "4": "ÔĄĎ",
            "5": "ÔĄĎ",
            "urgent": "ÔĀ™",
            "active": "ÔÜí",
            "default": "ÔĄĎ"
    }

    },

    "hyprland/submap": {
    "format": " {}",
    "max-length": 8,
    "tooltip": false
    },

    "sway/mode": {
    "format": " {}",
    "max-length": 8,
    "tooltip": false
    },

    "hyprland/language": {
    "format": "{}",
    "format-ru": "RU",
    "format-en": "US"
    },

    "sway/language": {
    "format": "{}",
    "format-ru": "RU",
    "format-en": "US"
    },

    "custom/notification": {
    "format": "{icon}",
    "format-icons": {
      "notification": "ÔāĘ<span foreground='red'><sup>ÔĎĄ</sup></span>",
      "none": " ÔāĘ ",
      "dnd-notification": "Ôá∑<span foreground='red'><sup>ÔĎĄ</sup></span>",
      "dnd-none": " Ôá∑ ",
      "inhibited-notification": "ÔāĘ<span foreground='red'><sup>ÔĎĄ</sup></span>",
      "inhibited-none": " ÔāĘ ",
      "dnd-inhibited-notification": "Ôá∑<span foreground='red'><sup>ÔĎĄ</sup></span>",
      "dnd-inhibited-none": "Ôá∑"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click-right": "swaync-client -t -sw",
    "on-click": "swaync-client -d -sw",
    "escape": true
  },




    "tray": {
        "spacing": 10,
        "tooltip": false
    },

    
    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "month",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "on-click-right": "mode",
            
        "format": {
            "months":     "<span color='#fabd2f'><b>{}</b></span>",    
            "days":       "<span color='#d3869b'><b>{}</b></span>",    
            "weeks":      "<span color='#8ec07c'><b>W{}</b></span>",   
            "weekdays":   "<span color='#fe8019'><b>{}</b></span>",   
            "today":      "<span color='#fb4934'><b><u>{}</u></b></span>" 
        }

        },
        "on-click-right": "pomotroid",
        "actions": {
            "on-click-middle": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        },
        "interval": 1
    },


    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["ůįÉě", "ůįÉü", "ůįÉĚ", "ůįÉ†"],
        "interval": 60,
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "on-click-right": "easygamma",
        "smooth-scrolling-threshold": 1,
        "tooltip": false,
        
        "states": {
            "low": 0,
            "medium": 50,
            "high": 75
        }
    },

    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "mode: {profile}\ndriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ůįĺÜ",
        "performance": "ůįďÖ",
        "balanced": "ůįĺÜ",
        "power-saver": "ůįĆ™"
      }
    },

    "battery": {
     "bat": "BAT0",
     "adapter": "AC",
     "format": "{icon} {capacity}%",
     "format-charging": "ůįāĄ {capacity}%",
     "format-plugged": "ůįāĄ {capacity}%",
     "format-icons": ["ůįāé", "ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"],
     "states": {
         "good": 100,
         "normal": 85,
         "warning": 30,
         "critical": 15
     },
     "interval": 10,
     "tooltip-format": "{time} | {power} W | health: {health}%"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ÔĀģ",
            "deactivated": "ÔĀį"
        },
        "tooltip": false
    },

    "pulseaudio": {
    "format": "{icon}{volume}%",
    "format-muted": "ÓĽ® 0%",
    "format-icons": {
        "default": ["ÔÄ¶ ", "ÔÄß ", "ÔÄ® "]
    },
    "scroll-step": 5,
    "max-volume": 100,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "tooltip": false
    }
}

